   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "# Dados\n",
    "data = {\n",
    "    \"nome\": [\"Ana\", \"Bruno\", \"Carlos\", \"Dina\", \"carlos\"],\n",
    "    \"idade\": [23, 35, 29, None, 40],\n",
    "    \"salario\": [50000, 70000, 60000, 65000, None],\n",
    "    \"departamento\": [\"IT\", \"HR\", \"IT\", \"Finance\", \"IT\"]\n",
    "}\n",
    "\n",
    "df = pd.DataFrame(data)\n",
    "\n",
    "# Padronizar nomes\n",
    "df[\"nome\"] = df[\"nome\"].str.capitalize()\n",
    "\n",
    "# Remover duplicatas\n",
    "df = df.drop_duplicates()\n",
    "\n",
    "# Preencher valores nulos\n",
    "df[\"idade\"].fillna(df[\"idade\"].mean(), inplace=True)\n",
    "df[\"salario\"].fillna(df[\"salario\"].mean(), inplace=True)\n",
    "\n",
    "# Análise básica\n",
    "print(df.describe())\n",
    "print(df[\"departamento\"].value_counts())\n",
    "\n",
    "# Maior salário\n",
    "maior_salario = df[\"salario\"].max()\n",
    "print(\"Maior salário:\", maior_salario)"
   ]
