    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Histograma de idades\n",
    "plt.figure()\n",
    "plt.hist(df[\"idade\"], bins=5)\n",
    "plt.title(\"Distribuição de Idades\")\n",
    "plt.xlabel(\"Idade\")\n",
    "plt.ylabel(\"Frequência\")\n",
    "plt.show()\n",
    "\n",
    "# Histograma de salários\n",
    "plt.figure()\n",
    "plt.hist(df[\"salario\"], bins=5)\n",
    "plt.title(\"Distribuição de Salários\")\n",
    "plt.xlabel(\"Salário\")\n",
    "plt.ylabel(\"Frequência\")\n",
    "plt.show()\n",
    "\n",
    "# Contagem por departamento\n",
    "df[\"departamento\"].value_counts().plot(kind=\"bar\")\n",
    "plt.title(\"Funcionários por Departamento\")\n",
    "plt.xlabel(\"Departamento\")\n",
    "plt.ylabel(\"Quantidade\")\n",
    "plt.show()\n",
    "\n",
    "# Salário por pessoa\n",
    "plt.figure()\n",
    "plt.bar(df[\"nome\"], df[\"salario\"])\n",
    "plt.title(\"Salário por Funcionário\")\n",
    "plt.xlabel(\"Nome\")\n",
    "plt.ylabel(\"Salário\")\n",
    "plt.show()"
