    "import numpy as np\n",
    "from sklearn.linear_model import LinearRegression\n",
    "\n",
    "x = np.array ([1, 2, 3, 4, 5, 6]).reshape(-1, 1);\n",
    "\n",
    "y = np.array ([7, 8, 9, 10, 13, 14])\n",
    "\n",
    "model = LinearRegression()\n",
    "\n",
    "model.fit(x, y)\n",
    "\n",
    "print(model.predict([[6]]))"
   ]
