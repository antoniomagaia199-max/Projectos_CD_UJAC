    "import pandas as pd\n",
    "from io import StringIO\n",
    "\n",
    "# Criar o CSV como texto\n",
    "data = \"\"\"nome,idade,curso,nota\n",
    "Ana,15,Informatica,17\n",
    "Joao,17,Biologia,17\n",
    "Manuel,16,Direito,13\n",
    "Ronaldo,19,Desporto,11\n",
    "Maria,10,Geografia,16\n",
    "Ana,15,Informatica,17\n",
    "\"\"\"\n",
    "\n",
    "# Ler CSV usando pandas\n",
    "df = pd.read_csv(StringIO(data))\n",
    "\n",
    "# Mostrar primeiras linhas do dataset\n",
    "print(\"Primeiras linhas:\")\n",
    "print(df.head())\n",
    "\n",
    "# Identificar valores nulos\n",
    "print(\"\\nValores nulos por coluna:\")\n",
    "print(df.isnull().sum())\n",
    "\n",
    "# Remover duplicados\n",
    "df = df.drop_duplicates()\n",
    "\n",
    "# Filtrar estudantes com notas maior que 15\n",
    "maior_15 = df[df['nota'] > 15]\n",
    "print(\"\\nEstudantes com nota maior que 15:\")\n",
    "print(maior_15)\n",
    "\n",
    "# Guardar como alunos_limpos.csv\n",
    "df.to_csv(\"alunos_limpos.csv\", index=False)\n",
    "\n",
    "print(\"\\nArquivo 'alunos_limpos.csv' guardado com sucesso!\")"
   ]
